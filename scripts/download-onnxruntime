#!/bin/bash
set -e

# ONNX Runtime PHP - Library Download Script
# Downloads prebuilt ONNX Runtime binaries for the current platform

VERSION="1.24.3"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="${PROJECT_ROOT}/lib"
RUNTIME="cpu"
PLATFORM=""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

print_heading() {
    echo -e "${GREEN}$1${NC}"
}

print_item() {
    local label="$1"
    local value="$2"
    echo -e "  - ${label}: ${YELLOW}${value}${NC}"
}

print_detail() {
    echo -e "  - $1"
}

print_warning() {
    echo -e "  - ${YELLOW}Warning${NC}: $1"
}

log_error() {
    echo -e "${RED}Error${NC}: $1" >&2
}

usage() {
    echo -e "${YELLOW}${BOLD}Usage:${NC}"
    echo -e "  ${CYAN}$0${NC} [--runtime <cpu|cuda12|cuda13>] [--platform <platform>] [--version <onnx-version>]"
    echo
    echo -e "${YELLOW}${BOLD}Options:${NC}"
    printf "  ${GREEN}%-20s${NC} %s\n" "--runtime" "Runtime variant to download (default: cpu)"
    printf "  ${GREEN}%-20s${NC} %s\n" "--platform" "Override detected platform (linux-x86_64, linux-arm64, darwin-arm64, windows-x64)"
    printf "  ${GREEN}%-20s${NC} %s\n" "--version" "ONNX Runtime version (default: ${VERSION})"
    printf "  ${GREEN}%-20s${NC} %s\n" "-h, --help" "Show help"
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --runtime)
                RUNTIME="$2"
                shift 2
                ;;
            --platform)
                PLATFORM="$2"
                shift 2
                ;;
            --version)
                VERSION="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done
}

normalize_runtime() {
    case "$RUNTIME" in
        cpu|cuda12|cuda13)
            ;;
        cuda)
            RUNTIME="cuda12"
            ;;
        *)
            log_error "Unsupported runtime: ${RUNTIME}. Supported values: cpu, cuda12, cuda13"
            exit 1
            ;;
    esac
}

# Detect platform
detect_platform() {
    local os
    local arch
    
    case "$OSTYPE" in
        linux*)
            os="linux"
            ;;
        darwin*)
            os="darwin"
            ;;
        msys*|cygwin*|mingw*)
            os="windows"
            ;;
        *)
            log_error "Unsupported operating system: $OSTYPE"
            exit 1
            ;;
    esac
    
    arch=$(uname -m)
    case "$arch" in
        x86_64|amd64)
            if [ "$os" = "windows" ]; then
                arch="x64"
            else
                arch="x86_64"
            fi
            ;;
        arm64|aarch64)
            arch="arm64"
            ;;
        *)
            log_error "Unsupported architecture: $arch"
            exit 1
            ;;
    esac
    
    echo "${os}-${arch}"
}

# Get download URL and filename for platform
get_download_info() {
    local platform=$1
    local runtime=$2
    
    if [ "$runtime" = "cpu" ]; then
        case "$platform" in
            linux-x86_64)
                filename="onnxruntime-linux-x64-${VERSION}.tgz"
                lib_name="libonnxruntime.so.${VERSION}"
                ;;
            linux-arm64)
                filename="onnxruntime-linux-aarch64-${VERSION}.tgz"
                lib_name="libonnxruntime.so.${VERSION}"
                ;;
            darwin-arm64)
                filename="onnxruntime-osx-arm64-${VERSION}.tgz"
                lib_name="libonnxruntime.${VERSION}.dylib"
                ;;
            windows-x64)
                filename="onnxruntime-win-x64-${VERSION}.zip"
                lib_name="onnxruntime.dll"
                ;;
            *)
                log_error "Runtime '${runtime}' is not supported on platform '${platform}'"
                log_error "Supported for '${runtime}': linux-x86_64, windows-x64"
                exit 1
                ;;
        esac
    elif [ "$runtime" = "cuda12" ]; then
        case "$platform" in
            linux-x86_64)
                filename="onnxruntime-linux-x64-gpu-${VERSION}.tgz"
                lib_name="libonnxruntime.so.${VERSION}"
                ;;
            windows-x64)
                filename="onnxruntime-win-x64-gpu-${VERSION}.zip"
                lib_name="onnxruntime.dll"
                ;;
            *)
                log_error "Runtime '${runtime}' is not supported on platform '${platform}'"
                log_error "Supported for '${runtime}': linux-x86_64, windows-x64"
                exit 1
                ;;
        esac
    else
        case "$platform" in
            linux-x86_64)
                filename="onnxruntime-linux-x64-gpu_cuda13-${VERSION}.tgz"
                lib_name="libonnxruntime.so.${VERSION}"
                ;;
            windows-x64)
                filename="onnxruntime-win-x64-gpu_cuda13-${VERSION}.zip"
                lib_name="onnxruntime.dll"
                ;;
            *)
                log_error "Unsupported platform for runtime '${runtime}': ${platform}"
                exit 1
                ;;
        esac
    fi
    
    url="https://github.com/microsoft/onnxruntime/releases/download/v${VERSION}/${filename}"
    
    echo "$filename|$lib_name|$url"
}

# Download and extract library
download_library() {
    local platform=$1
    local info
    local filename
    local lib_name
    local url
    local platform_dir
    
    info=$(get_download_info "$platform" "$RUNTIME")
    filename=$(echo "$info" | cut -d'|' -f1)
    lib_name=$(echo "$info" | cut -d'|' -f2)
    url=$(echo "$info" | cut -d'|' -f3)
    
    # Map platform to directory name
    case "$platform" in
        linux-x86_64|linux-arm64|darwin-arm64|windows-x64)
            platform_dir="$platform"
            ;;
        *)
            log_error "Unsupported platform directory mapping: ${platform}"
            exit 1
            ;;
    esac
    
    local platform_lib_dir="${LIB_DIR}/${platform_dir}/lib"
    
    # Check if already exists
    if [ -f "${platform_lib_dir}/${lib_name}" ]; then
        print_detail "ONNX Runtime library already exists for ${platform}"
        return 0
    fi

    print_heading "Downloading ONNX Runtime binaries"
    print_item "Runtime" "${RUNTIME}"
    print_item "Platform" "${platform}"
    print_item "Version" "${VERSION}"
    print_detail "Asset: ${filename}"
    
    # Create temp directory
    local temp_dir=$(mktemp -d)
    trap "rm -rf \"$temp_dir\"" EXIT
    
    # Download
    local download_path="${temp_dir}/${filename}"
    if command -v curl &> /dev/null; then
        curl -L -o "$download_path" "$url"
    elif command -v wget &> /dev/null; then
        wget -O "$download_path" "$url"
    else
        log_error "Neither curl nor wget is available"
        exit 1
    fi
    
    print_heading "Installing ONNX Runtime library"
    
    # Extract
    mkdir -p "$platform_lib_dir"
    
    if [[ "$filename" == *.tgz ]] || [[ "$filename" == *.tar.gz ]]; then
        tar -xzf "$download_path" -C "$temp_dir"
        local extracted_dir=$(find "$temp_dir" -maxdepth 1 -type d -name "onnxruntime-*" | head -1)
        cp "${extracted_dir}/lib/${lib_name}" "$platform_lib_dir/"
    elif [[ "$filename" == *.zip ]]; then
        if command -v unzip &> /dev/null; then
            unzip -q "$download_path" -d "$temp_dir"
            local extracted_dir=$(find "$temp_dir" -maxdepth 1 -type d -name "onnxruntime-*" | head -1)
            cp "${extracted_dir}/lib/${lib_name}" "$platform_lib_dir/"
        else
            log_error "unzip is required to extract Windows libraries"
            exit 1
        fi
    fi
    
    print_detail "Installed ${lib_name} to ${platform_lib_dir}"
}

# Main
main() {
    parse_args "$@"
    normalize_runtime

    local platform="${PLATFORM:-$(detect_platform)}"

    print_heading "Installing ONNX Runtime binaries"
    print_item "Version" "${VERSION}"
    print_item "Runtime" "${RUNTIME}"
    print_item "Platform" "${platform}"
    
    # Create lib directory if it doesn't exist
    mkdir -p "$LIB_DIR"
    
    download_library "$platform"
    
    print_heading "ONNX Runtime setup complete"
}

main "$@"
