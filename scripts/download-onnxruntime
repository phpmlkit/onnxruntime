#!/bin/bash
set -e

# ONNX Runtime PHP - Library Download Script
# Downloads prebuilt ONNX Runtime binaries for the current platform

VERSION="1.24.3"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="${PROJECT_ROOT}/lib"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Detect platform
detect_platform() {
    local os
    local arch
    
    case "$OSTYPE" in
        linux*)
            os="linux"
            ;;
        darwin*)
            os="osx"
            ;;
        msys*|cygwin*|mingw*)
            os="win"
            ;;
        *)
            log_error "Unsupported operating system: $OSTYPE"
            exit 1
            ;;
    esac
    
    arch=$(uname -m)
    case "$arch" in
        x86_64|amd64)
            arch="x64"
            ;;
        arm64|aarch64)
            if [ "$os" = "linux" ]; then
                arch="aarch64"
            else
                arch="arm64"
            fi
            ;;
        *)
            log_error "Unsupported architecture: $arch"
            exit 1
            ;;
    esac
    
    echo "${os}-${arch}"
}

# Get download URL and filename for platform
get_download_info() {
    local platform=$1
    
    case "$platform" in
        linux-x64)
            filename="onnxruntime-linux-x64-${VERSION}.tgz"
            lib_name="libonnxruntime.so.${VERSION}"
            ;;
        linux-aarch64)
            filename="onnxruntime-linux-aarch64-${VERSION}.tgz"
            lib_name="libonnxruntime.so.${VERSION}"
            ;;
        osx-arm64)
            filename="onnxruntime-osx-arm64-${VERSION}.tgz"
            lib_name="libonnxruntime.${VERSION}.dylib"
            ;;
        osx-x64)
            filename="onnxruntime-osx-x86_64-${VERSION}.tgz"
            lib_name="libonnxruntime.${VERSION}.dylib"
            ;;
        win-x64)
            filename="onnxruntime-win-x64-${VERSION}.zip"
            lib_name="onnxruntime.dll"
            ;;
        *)
            log_error "Unknown platform: $platform"
            exit 1
            ;;
    esac
    
    url="https://github.com/microsoft/onnxruntime/releases/download/v${VERSION}/${filename}"
    
    echo "$filename|$lib_name|$url"
}

# Download and extract library
download_library() {
    local platform=$1
    local info
    local filename
    local lib_name
    local url
    local platform_dir
    
    info=$(get_download_info "$platform")
    filename=$(echo "$info" | cut -d'|' -f1)
    lib_name=$(echo "$info" | cut -d'|' -f2)
    url=$(echo "$info" | cut -d'|' -f3)
    
    # Map platform to directory name
    case "$platform" in
        linux-x64)
            platform_dir="linux-x86_64"
            ;;
        linux-aarch64)
            platform_dir="linux-arm64"
            ;;
        osx-arm64)
            platform_dir="darwin-arm64"
            ;;
        osx-x64)
            platform_dir="darwin-x86_64"
            ;;
        win-x64)
            platform_dir="windows-x64"
            ;;
    esac
    
    local platform_lib_dir="${LIB_DIR}/${platform_dir}/lib"
    
    # Check if already exists
    if [ -f "${platform_lib_dir}/${lib_name}" ]; then
        log_info "ONNX Runtime library already exists for ${platform}"
        return 0
    fi
    
    log_info "Downloading ONNX Runtime ${VERSION} for ${platform}..."
    
    # Create temp directory
    local temp_dir=$(mktemp -d)
    trap "rm -rf $temp_dir" EXIT
    
    # Download
    local download_path="${temp_dir}/${filename}"
    if command -v curl &> /dev/null; then
        curl -L -o "$download_path" "$url"
    elif command -v wget &> /dev/null; then
        wget -O "$download_path" "$url"
    else
        log_error "Neither curl nor wget is available"
        exit 1
    fi
    
    log_info "Extracting library..."
    
    # Extract
    mkdir -p "$platform_lib_dir"
    
    if [[ "$filename" == *.tgz ]] || [[ "$filename" == *.tar.gz ]]; then
        tar -xzf "$download_path" -C "$temp_dir"
        local extracted_dir=$(find "$temp_dir" -maxdepth 1 -type d -name "onnxruntime-*" | head -1)
        cp "${extracted_dir}/lib/${lib_name}" "$platform_lib_dir/"
    elif [[ "$filename" == *.zip ]]; then
        if command -v unzip &> /dev/null; then
            unzip -q "$download_path" -d "$temp_dir"
            local extracted_dir=$(find "$temp_dir" -maxdepth 1 -type d -name "onnxruntime-*" | head -1)
            cp "${extracted_dir}/lib/${lib_name}" "$platform_lib_dir/"
        else
            log_error "unzip is required to extract Windows libraries"
            exit 1
        fi
    fi
    
    log_info "Library installed to: ${platform_lib_dir}/${lib_name}"
}

# Main
main() {
    log_info "ONNX Runtime PHP Library Manager"
    log_info "Version: ${VERSION}"
    
    local platform=$(detect_platform)
    log_info "Detected platform: ${platform}"
    
    # Create lib directory if it doesn't exist
    mkdir -p "$LIB_DIR"
    
    download_library "$platform"
    
    log_info "Library setup complete!"
}

main "$@"
