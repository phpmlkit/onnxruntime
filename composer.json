{
  "name": "phpmlkit/onnxruntime",
  "description": "High-performance ONNX Runtime bindings for PHP",
  "type": "platform-package",
  "readme": "README.md",
  "keywords": ["onnx", "onnxruntime", "machine-learning", "inference", "ml", "ai"],
  "homepage": "https://github.com/phpmlkit/onnxruntime",
  "license": "MIT",
  "authors": [
    {
      "name": "Kyrian Obikwelu",
      "email": "kyrian@example.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-ffi": "*",
    "codewithkyrian/platform-package-installer": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.0",
    "symfony/var-dumper": "^6.4.11|^7.1.5|^8.0",
    "phpmlkit/ndarray": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "PhpMlKit\\ONNXRuntime\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PhpMlKit\\ONNXRuntime\\Tests\\": "tests/"
    }
  },
  "bin": [
    "scripts/download-onnxruntime"
  ],
  "extra": {
    "artifacts": {
      "urls": {
        "linux-x86_64": "https://github.com/phpmlkit/onnxruntime/releases/download/{version}/dist-linux-x86_64-{runtime}.tar.gz",
        "linux-arm64": "https://github.com/phpmlkit/onnxruntime/releases/download/{version}/dist-linux-arm64-{runtime}.tar.gz",
        "darwin-arm64": "https://github.com/phpmlkit/onnxruntime/releases/download/{version}/dist-darwin-arm64-{runtime}.tar.gz",
        "windows-x64": "https://github.com/phpmlkit/onnxruntime/releases/download/{version}/dist-windows-x64-{runtime}.zip"
      },
      "vars": {
        "runtime": "cpu"
      }
    }
  },
  "scripts": {
    "post-install-cmd": "bash scripts/download-onnxruntime",
    "post-update-cmd": "bash scripts/download-onnxruntime",
    "test": "./vendor/bin/phpunit",
    "test:pretty": "./vendor/bin/phpunit --testdox",
    "test:coverage": "./vendor/bin/phpunit --coverage-text",
    "cs:fix": "./vendor/bin/php-cs-fixer fix",
    "cs:check": "./vendor/bin/php-cs-fixer fix --dry-run --diff",
    "lint": "./vendor/bin/phpstan analyse src tests --level=8"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "codewithkyrian/platform-package-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
